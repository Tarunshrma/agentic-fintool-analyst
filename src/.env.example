# OpenAI API key used by LlamaIndex/OpenAI.
# Replace the value in your copied .env file with your real key.
OPENAI_API_KEY=your-openai-api-key-here

# Official OpenAI endpoint. Leave this as-is for a normal OpenAI API key.
# If you later use Vocareum or another OpenAI-compatible endpoint, change this value.
OPENAI_API_BASE=https://api.openai.com/v1
